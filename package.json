{
  "name": "jokes-api",
  "version": "1.56.0",
  "description": "Lambda jokes API",
  "author": "David Bowland",
  "engines": {
    "node": "^24.0.0"
  },
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/davidbowland/jokes-api.git"
  },
  "bugs": {
    "url": "https://github.com/davidbowland/jokes-api/issues"
  },
  "homepage": "https://github.com/davidbowland/jokes-api#readme",
  "scripts": {
    "clean": "rm -rf .aws-sam coverage && NODE_ENV=test npm ci",
    "deploy": "NODE_ENV=production npm ci && ./scripts/deploy.sh",
    "lint": "prettier --write . && eslint --fix .",
    "prepare": "husky",
    "start": "./scripts/runLocal.sh",
    "test": "jest --colors",
    "typecheck": "tsc --noEmit",
    "update": "ncu --doctor --target minor --upgrade && npm audit fix --audit-level=none && npm run test && npm dedupe"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.1075.0",
    "@aws-sdk/client-polly": "^3.1075.0",
    "ajv": "^8.20.0",
    "aws-xray-sdk-core": "^3.12.0",
    "core-js": "^3.49.0",
    "esbuild": "^0.28.1",
    "fast-json-patch": "^3.1.1",
    "husky": "^9.1.7"
  },
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@babel/preset-env": "^7.29.7",
    "@babel/preset-typescript": "^7.29.7",
    "@trivago/prettier-plugin-sort-imports": "^5.2.2",
    "@types/aws-lambda": "^8.10.162",
    "@types/jest": "^29.5.14",
    "@types/node": "^24.13.2",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "babel-jest": "^29.7.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-jest": "^28.14.0",
    "jest": "^29.7.0",
    "lint-staged": "^14.0.1",
    "prettier": "^3.9.0",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "lint-staged": {
    "**/*.{js,jsx,ts,tsx}": [
      "prettier --write --ignore-unknown",
      "eslint --fix",
      "jest --colors --findRelatedTests --coverageThreshold '{}' --passWithNoTests"
    ],
    "**/*": [
      "prettier --write --ignore-unknown"
    ]
  }
}
