###############################################################################
# Jokes API - Endpoints
#
# Variables:
#   {{jokes-api-host}} - API host (e.g. jokes-api.dbowland.com)
#   {{jokes-token}}    - Bearer token (Cognito JWT)
#   {{id}}             - Joke ID (alphanumeric string, 6-8 characters)
###############################################################################

### Delete joke by ID
# Auth: Required (Bearer token)
# Path params: {id} - alphanumeric string, the joke ID to delete
# Response 200:
#   { "contents": "string", "audio": { "base64": "string", "contentType": "string", "version": "string" } | undefined }
# Response 204: No content (joke not found)
# Response 400: { "message": "string" } (missing or invalid ID)
# Response 500: { "message": "Internal server error" }

DELETE https://{{jokes-api-host}}/v1/jokes/{{id}} HTTP/1.1
Authorization: Bearer {{jokes-token}}

### Fetch all jokes
# Auth: Required (Bearer token)
# Response 200:
#   [
#     { "data": { "contents": "string" }, "id": "string" },
#     ...
#   ]
# Response 500: { "message": "Internal server error" }

GET https://{{jokes-api-host}}/v1/jokes HTTP/1.1
Authorization: Bearer {{jokes-token}}

### Fetch a single joke by ID
# Auth: None
# Path params: {id} - alphanumeric string, the joke ID
# Response 200:
#   {
#     "contents": "string",
#     "audio": { "base64": "string", "contentType": "string", "version": "string" } | undefined,
#     "id": "string"
#   }
# Response 400: { "message": "string" } (missing or invalid ID)
# Response 404: { "message": "Not found" } (joke not found)

GET https://{{jokes-api-host}}/v1/jokes/{{id}} HTTP/1.1

### Fetch text-to-speech audio for a joke
# Auth: None
# Path params: {id} - alphanumeric string, the joke ID
# Response 200:
#   Body: base64-encoded audio binary
#   Headers: { "content-type": "audio/mpeg" (or similar) }
#   isBase64Encoded: true
# Response 400: { "message": "string" } (missing or invalid ID)
# Response 404: { "message": "Not found" } (joke not found)
# Response 500: { "message": "Internal server error" } (Polly synthesis failed)

GET https://{{jokes-api-host}}/v1/jokes/{{id}}/tts HTTP/1.1

### Request random jokes
# Auth: None
# Query params:
#   count - integer, number of jokes to return (1 to 10, default 10)
#   avoid - comma-separated list of joke IDs to exclude
# Response 200:
#   [
#     { "data": { "contents": "string", "audio": { ... } | undefined }, "id": "string" },
#     ...
#   ]
# Response 404: { "message": "Not found" } (no jokes available)
# Response 500: { "message": "Internal server error" }

GET https://{{jokes-api-host}}/v1/jokes/random?count=5&avoid=abc123,def456 HTTP/1.1

### Change a joke (JSON Patch)
# Auth: Required (Bearer token)
# Path params: {id} - alphanumeric string, the joke ID
# Content-Type: application/json
# Request body (JSON Patch array):
#   [
#     { "op": "replace"|"add"|"remove"|"move"|"copy"|"test", "path": "string", "value": any }
#   ]
# Response 200:
#   { "contents": "string", "audio": { ... } | undefined }
# Response 400: { "message": "string" } (missing/invalid ID or invalid patch)
# Response 404: { "message": "Not found" } (joke not found)
# Response 409: { "message": "Version conflict" } (concurrent update conflict)
# Response 500: { "message": "Internal server error" }

PATCH https://{{jokes-api-host}}/v1/jokes/{{id}} HTTP/1.1
Authorization: Bearer {{jokes-token}}
Content-Type: application/json

[
  { "op": "replace", "path": "/contents", "value": "LOL" }
]

### Create a new joke
# Auth: Required (Bearer token)
# Content-Type: application/json
# Request body:
#   { "contents": "string" }
# Response 201:
#   { "contents": "string", "id": "string" }
#   Headers: { "Location": "https://{host}/v1/jokes/{id}" }
# Response 400: { "message": "string" } (invalid body / validation error)
# Response 500: { "message": "Internal server error" }

POST https://{{jokes-api-host}}/v1/jokes HTTP/1.1
Authorization: Bearer {{jokes-token}}
Content-Type: application/json

{
  "contents": "LOL"
}

### Migrate jokes (temporary)
# Auth: None
# Response 200:
#   { "migrated": number, "ids": ["string", ...] }
# Response 500: { "message": "Migration failed", "error": "string" }

POST https://{{jokes-api-host}}/v1/jokes/migrate HTTP/1.1
